# The Odds API (https://the-odds-api.com) — used by the `theodds` provider.
ODDS_API_KEY=your_the_odds_api_key_here

# Push notifications via ntfy.sh (default; zero-config, free).
# Pick a hard-to-guess topic name and subscribe to it in the ntfy app / https://ntfy.sh/<topic>.
NTFY_TOPIC=mrbet-alerts-change-me
# Optional: self-hosted ntfy server (defaults to https://ntfy.sh)
NTFY_SERVER=https://ntfy.sh

# Optional: Pushover instead of / in addition to ntfy.
# PUSHOVER_TOKEN=
# PUSHOVER_USER=

# SMS via email-to-SMS carrier gateway (stdlib smtplib, no extra deps).
# Enable in settings.yaml: notifications.sms: true
#
# SMS_EMAIL_TARGET  — carrier gateway address, e.g.:
#   AT&T:       10digitnumber@txt.att.net
#   T-Mobile:   10digitnumber@tmomail.net
#   Verizon:    10digitnumber@vtext.com
#   Sprint:     10digitnumber@messaging.sprintpcs.com
# SMS_EMAIL_TARGET=2125551234@txt.att.net
#
# SMTP_USERNAME   — sender address (Gmail recommended)
# SMTP_PASSWORD   — Gmail app-specific password (NOT your account password)
#   Generate one at: https://myaccount.google.com/apppasswords
#   (requires 2FA enabled on the account)
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# Optional overrides (defaults shown):
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# Discord webhook (recommended for instant phone push — fires only on flagged signals).
# Enable in settings.yaml: notifications.discord: true
#   Discord → Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
#   Then subscribe to that channel in the Discord mobile app for push alerts.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Slack incoming webhook (alternative to Discord).
# Enable in settings.yaml: notifications.slack: true
#   Slack → Apps → Incoming Webhooks → Add to a channel → Copy the webhook URL.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Driftwood (trend-following signal system) ---
# Polygon.io API key for the equities feed (`drift live --source polygon`).
# Free tier: https://polygon.io/dashboard/signup
# POLYGON_API_KEY=your_polygon_key_here
# (The default Yahoo Finance equity feed needs no key.)
