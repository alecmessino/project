# The Third Turn — secrets & config. Copy to `.env` (git-ignored) and fill in.
# NEVER commit the real .env. Values here are placeholders only.

# Discord webhook for validated CONFIRM/ARM alerts (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY
# Optional: ping on strong CONFIRM alerts — a numeric user id or the word "everyone". Leave blank for none.
DISCORD_PING=

# The Odds API key (https://the-odds-api.com). FREE tier = current-odds only (1 credit/call);
# odds_collector.py snapshots real pregame totals going forward.
ODDS_API_KEY=your_odds_api_key_here

# Odds Papi key (https://oddspapi.io). FREE tier HAS historical odds (since Jan 2026);
# odds_papi_history.py backfills real closing totals. Free plan = 250 requests total.
ODDS_PAPI_KEY=your_odds_papi_key_here
