# The Third Turn — secrets & config. Copy to `.env` (git-ignored) and fill in.
# NEVER commit the real .env. Values here are placeholders only.

# Discord webhook for validated CONFIRM/ARM alerts (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY
# Optional: ping on strong CONFIRM alerts — a numeric user id or the word "everyone". Leave blank for none.
DISCORD_PING=

# The Odds API key (https://the-odds-api.com). The FREE tier supports the CURRENT-odds
# endpoint (1 credit/call) used by odds_collector.py to snapshot real pregame totals going
# forward. HISTORICAL retro-fill of past seasons requires a PAID plan.
ODDS_API_KEY=your_odds_api_key_here
